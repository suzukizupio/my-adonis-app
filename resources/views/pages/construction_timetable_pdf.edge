<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>
      {{ construction.building_name || construction.name || construction.code || '工事' }}
      タイムテーブル
    </title>
    <style>
      @page {
        size: A4 landscape;
        margin: 8mm;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: #111827;
        font-family: 'Yu Gothic', 'YuGothic', 'Meiryo', 'Noto Sans JP', system-ui, sans-serif;
        font-size: 8pt;
        line-height: 1.35;
      }

      /* 時間帯チャンク（横幅に収まらず分割した場合）の区切りで改ページする */
      .timetable-page:not(:first-child) {
        break-before: page;
        page-break-before: always;
      }

      .pdf-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8mm;
        margin-bottom: 4mm;
      }

      .pdf-title p {
        margin: 0 0 1.5mm;
        color: #4b5563;
        font-size: 7pt;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .pdf-title h1 {
        margin: 0;
        font-size: 16pt;
        line-height: 1.15;
      }

      .pdf-meta {
        display: grid;
        grid-template-columns: auto auto;
        gap: 1.2mm 3mm;
        min-width: 64mm;
        color: #374151;
        font-size: 7pt;
        text-align: right;
      }

      .pdf-meta dt {
        color: #6b7280;
        font-weight: 700;
      }

      .pdf-meta dd {
        margin: 0;
      }

      .timetable-table {
        border-collapse: collapse;
        table-layout: fixed;
      }

      /* 縦に溢れて改ページされても、各印刷ページの先頭に時間帯の見出し行を繰り返す */
      .timetable-table thead {
        display: table-header-group;
      }

      /* 日付の行はページ境界で分断せず、行ごと次ページへ送る（＝改ページは必ず日付境界） */
      .timetable-table tbody tr {
        break-inside: avoid;
      }

      .timetable-table th,
      .timetable-table td {
        border: 0.45pt solid #9ca3af;
        padding: 1.7mm;
        text-align: left;
        vertical-align: top;
      }

      .timetable-table thead th {
        background: #eef2f7;
        color: #374151;
        font-size: 7pt;
        font-weight: 700;
      }

      .timetable-table thead th:first-child {
        text-align: center;
      }

      /* 左端の日付見出し列 */
      .timetable-table tbody th {
        color: #374151;
        font-size: 7pt;
        font-weight: 700;
        white-space: nowrap;
        text-align: center;
        vertical-align: middle;
        background: #f8fafc;
      }

      /* 午前→午後（昼休憩）の境界となる時間帯列の左に縦の区切り線を入れる */
      .timetable-table .is-afternoon-start-col {
        border-left: 1.3pt solid #374151;
      }

      .reservation-block {
        display: block;
        break-inside: avoid;
        min-height: 8.5mm;
        margin-bottom: 1.2mm;
        padding: 1.3mm 1.5mm;
        border: 0.75pt solid #1b4f8a;
        border-radius: 1.8mm;
        background: #1f6fb2;
        color: #ffffff;
      }

      .reservation-block:last-child {
        margin-bottom: 0;
      }

      .reservation-block strong {
        display: block;
        font-size: 8pt;
        font-weight: 700;
      }

      .reservation-block small {
        display: block;
        margin-top: 0.6mm;
        color: rgba(255, 255, 255, 0.88);
        font-size: 6.4pt;
      }

      .reservation-block.is-holiday {
        border-color: #737b85;
        background: #9ca3af;
      }

      .reservation-block.is-additional {
        border-color: #d97706;
      }

      .reservation-block.is-locked {
        border-color: #9ca3af;
        background: #f3f4f6;
        color: #111827;
      }

      .reservation-block.is-locked small {
        color: #374151;
      }

      .option-label {
        display: inline-block;
        margin-left: 1.4mm;
        padding: 0.2mm 1.2mm;
        border-radius: 999px;
        background: #ffffff;
        color: #1f6fb2;
        font-size: 5.8pt;
        font-weight: 700;
        vertical-align: 0.3mm;
      }

      .timetable-empty {
        color: #9ca3af;
      }

      .pdf-footer {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4mm;
        margin-top: 3mm;
        color: #6b7280;
        font-size: 6.8pt;
      }
    </style>
  </head>
  <body>
    @each((chunk, chunkIndex) in timetableChunks)
      <section class="timetable-page">
        <header class="pdf-header">
          <div class="pdf-title">
            <p>Timetable</p>
            <h1>
              {{
                construction.building_name ||
                construction.name ||
                construction.code ||
                '工事詳細'
              }}
            </h1>
          </div>
          <dl class="pdf-meta">
            <dt>工事ID</dt>
            <dd>{{ construction.itene_id }}</dd>
            <dt>工事期間</dt>
            <dd>
              {{ construction.whole_period_start_on || '-' }}
              /
              {{ construction.whole_period_end_on || '-' }}
            </dd>
            <dt>作業時間</dt>
            <dd>{{ construction.work_start_time || '-' }} - {{ construction.work_end_time || '-' }}</dd>
            <dt>出力日時</dt>
            <dd>{{ exportedAt }}</dd>
            @if(timetableChunks.length > 1)
              <dt>時間帯グループ</dt>
              <dd>{{ chunkIndex + 1 }} / {{ timetableChunks.length }}</dd>
            @end
          </dl>
        </header>

        <table
          class="timetable-table"
          style="width: {{ timetableDateLabelColMm + timetableSlotColMm * chunk.slots.length }}mm"
        >
          <colgroup>
            <col style="width: {{ timetableDateLabelColMm }}mm" />
            @each(slot in chunk.slots)
              <col style="width: {{ timetableSlotColMm }}mm" />
            @end
          </colgroup>
          <thead>
            <tr>
              <th>日付</th>
              @each(slot in chunk.slots)
                <th class="{{ slot.isAfternoonStart ? 'is-afternoon-start-col' : '' }}">
                  {{ slot.timeRange }}
                </th>
              @end
            </tr>
          </thead>
          <tbody>
            @if(chunk.slots.length === 0)
              <tr>
                <td>予約データはありません</td>
              </tr>
            @else
              @each(row in chunk.rows)
                <tr>
                  <th>{{ row.dateLabel }}</th>
                  @each(cell in row.cells)
                    <td class="{{ cell.isAfternoonStart ? 'is-afternoon-start-col' : '' }}">
                      @each(holiday in cell.holidays)
                        <span class="reservation-block is-holiday">
                          <strong>{{ holiday.name }}</strong>
                          <small>{{ holiday.timeRange }}</small>
                        </span>
                      @end
                      @each(reservation in cell.reservations)
                        <span
                          class="reservation-block {{ reservation.additionalFlag ? 'is-additional' : '' }} {{ reservation.lockRoomOwner ? 'is-locked' : '' }}"
                        >
                          <strong>
                            {{ reservation.roomNo }}
                            @if(reservation.hasOption)
                              <span class="option-label">OP</span>
                            @end
                          </strong>
                          <small>{{ reservation.timeRange }}</small>
                        </span>
                      @end
                      @if(cell.holidays.length === 0 && cell.reservations.length === 0)
                        <span class="timetable-empty">-</span>
                      @end
                    </td>
                  @end
                </tr>
              @end
            @end
          </tbody>
        </table>

        <footer class="pdf-footer">
          <span>青: 予約</span>
          <span>灰: 休工</span>
          <span>OP: オプション申込あり</span>
        </footer>
      </section>
    @end
  </body>
</html>
